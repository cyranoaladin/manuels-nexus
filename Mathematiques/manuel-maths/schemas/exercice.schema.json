{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "exercice.schema.json",
  "title": "Métadonnées d'un exercice du manuel",
  "type": "object",
  "required": ["id", "chapitre", "capacites", "parcours", "competences", "duree_min", "mode_creation", "fichier_tex", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z0-9]+-[A-Z]+-EX-[0-9]{3}$" },
    "chapitre": { "type": "string" },
    "capacites": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "methodes": { "type": "array", "items": { "type": "string" } },
    "parcours": { "type": "integer", "minimum": 1, "maximum": 3 },
    "competences": {
      "type": "array", "minItems": 1,
      "items": { "enum": ["chercher", "modeliser", "representer", "calculer", "raisonner", "communiquer"] }
    },
    "duree_min": { "type": "integer", "minimum": 2, "maximum": 90 },
    "mode_creation": { "enum": ["adaptation", "inspiration", "ex_nihilo"] },
    "sources_inspiration": { "type": "array", "items": { "type": "string" } },
    "parametres_sympy": {
      "type": "object",
      "description": "Variables paramétrées : {nom: {domaine, contraintes}} pour génération de variantes",
      "additionalProperties": true
    },
    "coups_de_pouce": { "type": "array", "maxItems": 3, "items": { "type": "string" } },
    "fichier_tex": { "type": "string" },
    "corrige_tex": { "type": "string" },
    "status": { "enum": ["draft", "generated", "verified", "manual_review", "ready", "rejected"] }
  }
}
